# AI API Configuration (xAI Grok or OpenAI-compatible)
AI_API_KEY=your_api_key_here
AI_API_BASE=https://api.x.ai/v1
AI_MODEL=grok-4-1-fast-non-reasoning
MOCK_MODE=0

# Mattermost Webhook Configuration
MATTERMOST_WEBHOOK_URL=https://your-mattermost.example.com/hooks/your_webhook_id
MATTERMOST_USERNAME=Daily Newsletter Bot
MATTERMOST_ICON_URL=

# RSS Fetch Configuration
MAX_PER_FEED=6
MAX_PER_SECTION_INPUT=20
MAX_MATTERMOST_TEXT=12000

# Output Paths
OUTPUT_HTML_PATH=output/newsletter.html
SUMMARY_FILE_PATH=output/summary.md
